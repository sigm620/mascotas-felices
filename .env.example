# ── Base de datos (Neon) ────────────────────────────────────────
# Copia el "Connection string" de tu proyecto Neon
# Formato: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://usuario:contraseña@host.neon.tech/mascotas?sslmode=require

# ── Sesiones ────────────────────────────────────────────────────
# Cadena aleatoria larga y segura (Render la genera automáticamente)
SESSION_SECRET=cambia_esto_por_una_clave_secreta_larga

# ── Entorno ─────────────────────────────────────────────────────
NODE_ENV=production

# ── Puerto (Render lo asigna solo, no necesitas cambiarlo) ──────
PORT=10000
